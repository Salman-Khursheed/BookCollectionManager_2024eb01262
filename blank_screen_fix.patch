From 8f01750e259b33357452771a85e2229df5adfeb3 Mon Sep 17 00:00:00 2001
From: Claude <claude@anthropic.com>
Date: Mon, 22 Jun 2026 11:49:26 +0000
Subject: [PATCH] fix: remove duplicate xmlns and negative margin causing blank
 screen

---
 app/src/main/res/layout/activity_main.xml | 25 +++++++++++++----------
 1 file changed, 14 insertions(+), 11 deletions(-)

diff --git a/app/src/main/res/layout/activity_main.xml b/app/src/main/res/layout/activity_main.xml
index 18d319f..25fd29e 100644
--- a/app/src/main/res/layout/activity_main.xml
+++ b/app/src/main/res/layout/activity_main.xml
@@ -12,10 +12,10 @@
         android:layout_height="wrap_content"
         android:orientation="vertical">
 
-        <!-- ── Header ── -->
+        <!-- Header -->
         <FrameLayout
             android:layout_width="match_parent"
-            android:layout_height="220dp"
+            android:layout_height="200dp"
             android:background="@drawable/bg_header">
 
             <LinearLayout
@@ -52,16 +52,17 @@
             </LinearLayout>
         </FrameLayout>
 
-        <!-- ── Form Card ── -->
+        <!-- Form Card -->
         <androidx.cardview.widget.CardView
-            xmlns:card_view="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
-            android:layout_margin="20dp"
-            android:layout_marginTop="-28dp"
-            card_view:cardCornerRadius="20dp"
-            card_view:cardElevation="8dp"
-            card_view:cardBackgroundColor="@color/cardBackground">
+            android:layout_marginLeft="16dp"
+            android:layout_marginRight="16dp"
+            android:layout_marginTop="16dp"
+            android:layout_marginBottom="16dp"
+            app:cardCornerRadius="20dp"
+            app:cardElevation="8dp"
+            app:cardBackgroundColor="@color/cardBackground">
 
             <LinearLayout
                 android:layout_width="match_parent"
@@ -78,7 +79,7 @@
                     android:textStyle="bold"
                     android:layout_marginBottom="20dp" />
 
-                <!-- Title field -->
+                <!-- Title label -->
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
@@ -89,6 +90,7 @@
                     android:letterSpacing="0.06"
                     android:layout_marginBottom="6dp" />
 
+                <!-- Title input row -->
                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
@@ -120,7 +122,7 @@
                         android:autofillHints="none" />
                 </LinearLayout>
 
-                <!-- Author field -->
+                <!-- Author label -->
                 <TextView
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
@@ -131,6 +133,7 @@
                     android:letterSpacing="0.06"
                     android:layout_marginBottom="6dp" />
 
+                <!-- Author input row -->
                 <LinearLayout
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
-- 
